# ================================
# PayTransit Analytics Service
# Environment Configuration
# ================================

# Application
APP_NAME=CityTransit Analytics Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ================================
# OpenAI / LangChain (Agentes IA)
# ================================
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo a usar (opciones: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o-mini

# Temperatura (0=determinístico, 1=creativo)
OPENAI_TEMPERATURE=0.7

# Mostrar logs detallados de LangChain
LANGCHAIN_VERBOSE=true

# ================================
# LLM Alternativo: Ollama (LOCAL - GRATIS)
# ================================
# Ollama es un LLM que corre localmente en tu máquina.
# NO requiere API key ni conexión a internet.
# Instalar: https://ollama.ai
# Luego ejecutar: ollama serve && ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ================================
# LLM Alternativo: Groq (API GRATIS)
# ================================
# Groq ofrece API gratuita ultrarrápida (con rate limits).
# Obtener key gratis en: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ================================
# LLM Alternativo: HuggingFace (Open Source)
# ================================
# HuggingFace funciona sin API key (con rate limits).
# Con API key tienes mayor límite: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ================================
# Prioridad de Proveedores LLM
# ================================
# El sistema intentará usar el primer proveedor disponible en este orden.
# Opciones: ollama, groq, huggingface, openai
LLM_PROVIDER_PRIORITY=ollama,groq,huggingface,openai

# ================================
# ClickHouse (Analytics OLAP)
# ================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=paytransit

# ================================
# MongoDB (Documentos/Reportes)
# ================================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=admin123
MONGODB_DATABASE=paytransit

# ================================
# Redis (Cache)
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redfire007
REDIS_DB=0

# ================================
# PostgreSQL (Backend Java)
# ================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=paytransit

# ================================
# Java Backend Integration
# ================================
BACKEND_URL=http://localhost:8080
BACKEND_API_KEY=

# ================================
# JWT Authentication
# ================================
JWT_SECRET=your-secret-key-minimum-256-bits-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ================================
# ML Models
# ================================
MODEL_PATH=./models
LSTM_MODEL_PATH=./models/lstm_demand_prediction.h5
BERT_MODEL_PATH=./models/bert_sentiment_analysis

# ================================
# Cache
# ================================
CACHE_TTL=3600
